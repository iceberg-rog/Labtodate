# lab2date local development environment.
# Copy to .env.local for `npm run dev`, or use .env.docker.example for Docker.

# Database
DATABASE_URL="postgresql://lab2date:lab2date@127.0.0.1:16543/lab2date?schema=public"

# Auth
BETTER_AUTH_SECRET="change-me-in-prod-min-32-chars-please"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Site / company identity
SITE_NAME="lab2date"
SUPPORT_EMAIL="support@lab2date.local"
COMPANY_LEGAL_NAME="lab2date"
COMPANY_ADDRESS=""
COMPANY_COUNTRY=""
COMPANY_PHONE=""
COMPANY_EMAIL="billing@lab2date.local"
COMPANY_VAT=""
COMPANY_LOGO_URL=""
COMPANY_RECEIVING_ADDRESS=""

# Email
RESEND_API_KEY=""
RESEND_SMTP_PORT="2587"
EMAIL_FROM="no-reply@lab2date.local"
SMTP_HOST="localhost"
SMTP_PORT="11025"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE=""
SELL_INTAKE_EMAIL="acquisitions@lab2date.local"
QUOTE_INTAKE_EMAIL="sourcing@lab2date.local"
SUPPORT_INTAKE_EMAIL="support@lab2date.local"
EMAIL_THROTTLE_HOURS="2"

# Object storage: local MinIO
S3_ENDPOINT="http://localhost:19000"
S3_PUBLIC_URL="http://localhost:19000/lab2date-media"
S3_REGION="us-east-1"
S3_BUCKET="lab2date-media"
S3_ACCESS_KEY="lab2date"
S3_SECRET_KEY="lab2date-secret"

# Search: optional Algolia; blank uses Postgres ILIKE.
ALGOLIA_APP_ID=""
ALGOLIA_ADMIN_KEY=""
NEXT_PUBLIC_ALGOLIA_APP_ID=""
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=""
NEXT_PUBLIC_ALGOLIA_INDEX="lab2date_products"

# Payments
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
BANK_NAME=""
BANK_IBAN=""
BANK_SWIFT=""
BANK_REFERENCE_HINT="Use the order/proforma number as transfer reference"
PROFORMA_VALID_DAYS="14"

# Commerce defaults
DEFAULT_SHIPPING_CENTS="0"
DEFAULT_TAX_PERCENT="0"
ORPHAN_ORDER_TTL_MINUTES="10080"

# Seller-facing copy
SELLER_COMMISSION_PCT="8"
SELLER_LISTING_FEE="Free"
SELLER_PAYOUT_DAYS="3 business days after delivery"

# Marketing copy overrides
STAT_LISTINGS=""
STAT_SUPPLIERS=""
QUOTE_TURNAROUND="5 business days"
WARRANTY_TEXT="90-day warranty"
INSPECTION_TEXT="14-point inspection"
FINANCING_TEXT=""
FOOTER_TAGLINE="B2B marketplace for laboratory and biotech equipment."
SOCIAL_LINKEDIN=""
SOCIAL_TWITTER=""
SOCIAL_GITHUB=""
HOMEPAGE_SECTIONS=""
HOMEPAGE_POPULAR=""
HERO_BADGE=""
HERO_TITLE=""
HERO_ACCENT=""
HERO_SUBTITLE=""
HERO_STATS=""
TEST_HEADING=""
TEST_META=""
CTA_HEADING=""
CTA_SUBTITLE=""

# AI assistant (OpenAI-compatible)
AI_API_KEY=""
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"
ASSISTANT_NAME="lab2date Assistant"

# Internal cron
CRON_SECRET="change-me-cron-secret-min-32-chars"
